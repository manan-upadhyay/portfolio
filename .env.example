# --- Resend (server-side email for the Summon / contact form) ---
# Create / regenerate a key at https://resend.com/api-keys
# This is a SERVER secret (no VITE_ prefix) — it is never exposed to the browser.
RESEND_API_KEY="re_xxxxxxxxx"

# Inbox that receives contact submissions.
# NOTE: while using the test sender (onboarding@resend.dev), this MUST be the
# email of your Resend account. After verifying a domain you can use any address.
RESEND_TO="upadhyaymanan01@gmail.com"

# Verified sender address. Use onboarding@resend.dev for testing only;
# in production set this to an address on a domain verified at
# https://resend.com/domains  e.g. "The Chronicle <hello@yourdomain.com>"
RESEND_FROM="The Chronicle <onboarding@resend.dev>"
